@{
    ViewData["Title"] = "Hava Durumu";
    ViewData["Page"] = "weather";
}

<div class="kpi-grid" style="margin-bottom:24px">
    <div class="kpi-card">
        <div class="kpi-header">
            <span class="kpi-label">Sıcaklık</span>
            <div class="kpi-icon" style="background:rgba(240,136,62,0.15)">
                <i class="bi bi-thermometer-half" style="color:#f0883e"></i>
            </div>
        </div>
        <div class="kpi-value" id="wTemp">—</div>
        <div class="kpi-sub">°C</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-header">
            <span class="kpi-label">Güneş Işınımı</span>
            <div class="kpi-icon" style="background:rgba(210,153,34,0.15)">
                <i class="bi bi-brightness-high-fill" style="color:#d29922"></i>
            </div>
        </div>
        <div class="kpi-value" id="wIrr">—</div>
        <div class="kpi-sub">W/m²</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-header">
            <span class="kpi-label">Bulutluluk</span>
            <div class="kpi-icon" style="background:rgba(139,148,158,0.15)">
                <i class="bi bi-clouds" style="color:#8b949e"></i>
            </div>
        </div>
        <div class="kpi-value" id="wCloud">—</div>
        <div class="kpi-sub">%</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-header">
            <span class="kpi-label">Rüzgar Hızı</span>
            <div class="kpi-icon" style="background:rgba(88,166,255,0.15)">
                <i class="bi bi-wind" style="color:#58a6ff"></i>
            </div>
        </div>
        <div class="kpi-value" id="wWind">—</div>
        <div class="kpi-sub">m/s</div>
    </div>
</div>

<!-- Hava & Üretim ilişkisi -->
<div class="chart-card" style="margin-bottom:24px">
    <div class="chart-card-header">
        <div>
            <div class="chart-title">Güneş Işınımı & Üretim İlişkisi</div>
            <div class="chart-subtitle">Hava koşullarının üretime etkisi</div>
        </div>
    </div>
    <canvas id="weatherImpactChart" height="80"></canvas>
</div>

<!-- Durum kartı -->
<div class="chart-card">
    <div class="chart-card-header">
        <div class="chart-title">Genel Durum</div>
    </div>
    <div class="d-flex align-items-center gap-4 p-2">
        <i class="bi bi-cloud-sun-fill" style="font-size:64px; color:#d29922"></i>
        <div>
            <div style="font-size:28px; font-weight:700" id="wCondition">—</div>
            <div style="color:var(--text-muted); margin-top:4px" id="wTime">—</div>
            <div style="margin-top:8px">
                <span class="kpi-badge badge-orange">
                    <!--   <i class="bi bi-geo-alt"></i> Konum    -->
                </span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadWeatherPage() {
            const res  = await fetch('/api/energy/weather');
            const data = await res.json();

            document.getElementById('wTemp').textContent      = data.temperature;
            document.getElementById('wIrr').textContent       = data.solarIrradiance;
            document.getElementById('wCloud').textContent     = data.cloudCover;
            document.getElementById('wWind').textContent      = data.windSpeed;
            document.getElementById('wCondition').textContent = data.condition;
            document.getElementById('wTime').textContent      =
                'Son güncelleme: ' + new Date(data.timestamp)
                    .toLocaleTimeString('tr-TR', { hour:'2-digit', minute:'2-digit' });

            // Üretim verisiyle birleştir
            const predRes  = await fetch('/api/energy/predictions/today');
            const predData = await predRes.json();

            const labels = predData.map(d => new Date(d.timestamp).getHours() + ':00');

            new Chart(document.getElementById('weatherImpactChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        {
                            label: 'Üretim (kW)',
                            data: predData.map(d => d.predictedKw),
                            borderColor: '#3fb950',
                            backgroundColor: 'rgba(63,185,80,0.08)',
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            yAxisID: 'y'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top', labels: { boxWidth: 12 } } },
                    scales: {
                        x: { grid: { color: '#30363d' } },
                        y: { grid: { color: '#30363d' },
                             title: { display: true, text: 'kW' } }
                    }
                }
            });
        }

        document.addEventListener('DOMContentLoaded', loadWeatherPage);
    </script>
}