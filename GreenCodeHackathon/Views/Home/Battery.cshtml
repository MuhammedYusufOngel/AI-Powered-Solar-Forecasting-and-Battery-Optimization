@{
    ViewData["Title"] = "Batarya Yönetimi";
    ViewData["Page"] = "battery";
}

<div class="chart-grid" style="margin-bottom:24px">
    <div class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-title">24 Saatlik Doluluk Geçmişi</div>
                <div class="chart-subtitle">% cinsinden batarya seviyesi</div>
            </div>
        </div>
        <canvas id="batteryHistoryChart" height="120"></canvas>
    </div>

    <div class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-title">Karar Dağılımı</div>
                <div class="chart-subtitle">CHARGE / DISCHARGE / IDLE oranı</div>
            </div>
        </div>
        <canvas id="decisionPieChart" height="120"></canvas>
    </div>
</div>

<!-- Anlık durum kartı -->
<div class="chart-card" style="margin-bottom:24px">
    <div class="chart-card-header">
        <div class="chart-title">Anlık Batarya Durumu</div>
    </div>
    <div class="row g-4" id="batteryCurrentInfo">
        <div class="col-md-3 text-center">
            <div style="font-size:52px; font-weight:700; color:#3fb950" id="bLivePercent">—%</div>
            <div style="color:var(--text-muted); font-size:13px">Doluluk</div>
        </div>
        <div class="col-md-3 text-center">
            <div style="font-size:32px; font-weight:700; color:#58a6ff" id="bLivePower">— kW</div>
            <div style="color:var(--text-muted); font-size:13px">Anlık Güç</div>
        </div>
        <div class="col-md-3 text-center">
            <div style="font-size:32px; font-weight:700; color:#d29922" id="bLiveCapacity">— kWh</div>
            <div style="color:var(--text-muted); font-size:13px">Toplam Kapasite</div>
        </div>
        <div class="col-md-3 text-center">
            <div class="decision-badge decision-idle" id="bLiveDecision" style="font-size:16px; padding:10px 20px">
                <i class="bi bi-dash-circle"></i> —
            </div>
            <div style="color:var(--text-muted); font-size:12px; margin-top:8px" id="bLiveReason">—</div>
        </div>
    </div>
</div>

<!-- Geçmiş tablosu -->
<div class="table-card">
    <div class="table-card-header">
        <i class="bi bi-clock-history me-2"></i>Karar Geçmişi
    </div>
    <div class="table-responsive">
        <table class="table table-dark-custom table-hover">
            <thead>
                <tr><th>Saat</th><th>Karar</th><th>Doluluk</th><th>Güç (kW)</th><th>Gerekçe</th></tr>
            </thead>
            <tbody id="batteryDetailTable">
                <tr><td colspan="5" class="text-center text-muted py-4">Yükleniyor...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>

            function toLocalTime(utcStr) {
            // SQLite'tan gelen string'e Z ekle (UTC olduğunu belirt)
            const str = utcStr.endsWith('Z') ? utcStr : utcStr + 'Z';
            return new Date(str);
        }
        async function loadBatteryPage() {
            const [latestRes, historyRes] = await Promise.all([
                fetch('/api/energy/battery/latest'),
                fetch('/api/energy/battery/history')
            ]);
            const latest  = await latestRes.json();
            const history = await historyRes.json();

            // Anlık bilgiler
            const pct = latest.chargePercent;
            document.getElementById('bLivePercent').textContent   = pct.toFixed(1) + '%';
            document.getElementById('bLivePercent').style.color   =
                pct > 60 ? '#3fb950' : pct > 30 ? '#f0883e' : '#f85149';
            document.getElementById('bLivePower').textContent     =
                (latest.currentPowerKw > 0 ? '+' : '') + latest.currentPowerKw + ' kW';
            document.getElementById('bLiveCapacity').textContent  = latest.capacityKwh + ' kWh';
            document.getElementById('bLiveReason').textContent    = latest.decisionReason;

            const badge = document.getElementById('bLiveDecision');
            badge.className = 'decision-badge ' + (
                latest.decision === 'CHARGE'    ? 'decision-charge' :
                latest.decision === 'DISCHARGE' ? 'decision-discharge' : 'decision-idle');
            const icon = latest.decision === 'CHARGE'    ? 'arrow-up-circle'
                       : latest.decision === 'DISCHARGE' ? 'arrow-down-circle' : 'dash-circle';
            badge.innerHTML = `<i class="bi bi-${icon}"></i> ${latest.decision}`;

            // Doluluk geçmiş grafiği
                const labels = history.map(h =>
                        toLocalTime(h.timestamp).getHours() + ':00');
            
                        console.log(history)

            new Chart(document.getElementById('batteryHistoryChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        label: 'Doluluk (%)',
                        data: history.map(h => h.chargePercent),
                        borderColor: '#58a6ff',
                        backgroundColor: 'rgba(88,166,255,0.1)',
                        borderWidth: 2,
                        tension: 0.4,
                        fill: true,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top', labels: { boxWidth: 12 } } },
                    scales: {
                        x: { grid: { color: '#30363d' } },
                        y: { min: 0, max: 100, grid: { color: '#30363d' },
                             ticks: { callback: v => v + '%' } }
                    }
                }
            });

            // Karar dağılımı pasta grafiği
            const charge    = history.filter(h => h.decision === 'CHARGE').length;
            const discharge = history.filter(h => h.decision === 'DISCHARGE').length;
            const idle      = history.filter(h => h.decision === 'IDLE').length;

            new Chart(document.getElementById('decisionPieChart').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['CHARGE', 'DISCHARGE', 'IDLE'],
                    datasets: [{
                        data: [charge, discharge, idle],
                        backgroundColor: ['#3fb950', '#f0883e', '#8b949e'],
                        borderColor: '#1c2128',
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { boxWidth: 12, padding: 16 } }
                    },
                    cutout: '65%'
                }
            });

            // Tablo
            const tbody = document.getElementById('batteryDetailTable');
            tbody.innerHTML = history.slice().reverse().map(b => {
                const badgeClass = b.decision === 'CHARGE'    ? 'badge-green'
                                 : b.decision === 'DISCHARGE' ? 'badge-orange' : 'badge-blue';
                    const saat = toLocalTime(b.timestamp)
                            .toLocaleTimeString('tr-TR', { hour:'2-digit', minute:'2-digit' });
                return `
                <tr>
                    <td>${saat}</td>
                    <td><span class="kpi-badge ${badgeClass}">${b.decision}</span></td>
                    <td>${b.chargePercent.toFixed(1)}%</td>
                    <td style="color:${b.currentPowerKw > 0 ? '#3fb950'
                                      : b.currentPowerKw < 0 ? '#f85149' : '#8b949e'}">
                        ${b.currentPowerKw > 0 ? '+' : ''}${b.currentPowerKw}
                    </td>
                    <td style="color:var(--text-secondary)">${b.decisionReason}</td>
                </tr>`;
            }).join('');
        }

        document.addEventListener('DOMContentLoaded', loadBatteryPage);
    </script>
}